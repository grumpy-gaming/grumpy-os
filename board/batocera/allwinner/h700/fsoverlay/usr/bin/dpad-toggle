#!/bin/bash

# We only want to run the script if the board has no analog stick capability
if knulli-board-capability "analogstick"; then
    exit 1
fi

DPAD_STATE_FILE="/sys/class/power_supply/axp2202-battery/nds_pwrkey"
STATE=$(cat "$DPAD_STATE_FILE")

if [ "${STATE}" -eq 0 ]; then
    knulli-rumble 0.1
    echo 2 > "$DPAD_STATE_FILE"
else
    knulli-rumble 0.1
    sleep 0.2
    knulli-rumble 0.1
    echo 0 > "$DPAD_STATE_FILE"
fi

exit 0
